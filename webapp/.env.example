# Azure AD (Entra ID) app registration
AAD_TENANT_ID=your-tenant-id
AAD_CLIENT_ID=your-app-client-id
AAD_CLIENT_SECRET=your-app-client-secret
AAD_REDIRECT_URI=http://localhost:3000/auth/callback

# Express session
SESSION_SECRET=change-me-to-a-long-random-string

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=yourstorageaccount
AZURE_STORAGE_CONTAINER=vendor-uploads
# Either use connection string OR rely on DefaultAzureCredential (managed identity)
AZURE_STORAGE_CONNECTION_STRING=

# Azure DevOps
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PROJECT=your-project
ADO_PIPELINE_ID=123
ADO_PAT=your-personal-access-token-with-Build-RW

# App
PORT=3000
